<!-- Session window: launcher grid with session-related actions -->

<div class="window-session-wrapper">
  <div class="users-launcher-grid" aria-label="Atalhos de sessão">
    <!-- Session info icon opens a child window with smaller size -->
    <button
      type="button"
      class="users-launcher-icon desktop-icon"
      data-open-window="session-info"
      data-parent-window="session"
      data-hide-window-on-open="1"
      title="Detalhes de Sessão"
    >
      <span class="desktop-icon-face desktop-icon-folder">
        <span class="desktop-icon-folder-main" aria-hidden="true">📁</span>
        <span class="desktop-icon-folder-badge" aria-hidden="true">ℹ️</span>
      </span>
      <span class="desktop-icon-label">Detalhes</span>
      <span class="users-launcher-caption">Ver info</span>
    </button>

    <!-- Change password icon -->
    <button
      type="button"
      class="users-launcher-icon desktop-icon"
      data-open-window="session-password"
      data-parent-window="session"
      data-hide-window-on-open="1"
      title="Mudar Password"
    >
      <span class="desktop-icon-face desktop-icon-folder">
        <span class="desktop-icon-folder-main" aria-hidden="true">📁</span>
        <span class="desktop-icon-folder-badge" aria-hidden="true">🔐</span>
      </span>
      <span class="desktop-icon-label">Mudar Password</span>
      <span class="users-launcher-caption">Abrir</span>
    </button>
  </div>
</div>

