<!-- Generic window frame with titlebar, close button, and content slot -->
<!-- Usage: <%- include('app/window-frame', { windowId, windowTitle, windowContent }) %> -->

<div class="desktop-window window-<%= windowId %>" id="window-<%= windowId %>" hidden>
  <div class="desktop-window-titlebar has-traffic-controls">
    <div class="desktop-window-titlebar-controls" aria-label="Controlo da janela">
      <button
        type="button"
        class="desktop-window-traffic-light red"
        data-close-window="<%= windowId %>"
        aria-label="Fechar janela"
        title="Fechar"
      ></button>
      <span class="desktop-window-traffic-light yellow" aria-hidden="true"></span>
      <span class="desktop-window-traffic-light green" aria-hidden="true"></span>
    </div>
    <strong class="desktop-window-title"><%= windowTitle %></strong>
  </div>
  <div class="desktop-window-content">
    <%- windowContent %>
  </div>
</div>
