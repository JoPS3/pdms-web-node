<!-- Users window: icon launcher kept inside app view scope -->

<section class="window-users-wrapper">
  <div class="users-launcher-grid" aria-label="Atalhos de utilizadores">
    <a
      href="<%= usersListPath %>"
      class="users-launcher-icon desktop-icon"
      title="Lista de Utilizadores"
    >
      <span class="desktop-icon-face desktop-icon-folder">
        <span class="desktop-icon-folder-main" aria-hidden="true">📁</span>
        <span class="desktop-icon-folder-badge" aria-hidden="true">👥</span>
      </span>
      <span class="desktop-icon-label">Lista</span>
      <span class="users-launcher-caption">Abrir</span>
    </a>

    <a
      href="#"
      class="users-launcher-icon desktop-icon is-disabled"
      aria-disabled="true"
      title="Perfis e Papéis (em breve)"
    >
      <span class="desktop-icon-face desktop-icon-folder">
        <span class="desktop-icon-folder-main" aria-hidden="true">📁</span>
        <span class="desktop-icon-folder-badge" aria-hidden="true">🔑</span>
      </span>
      <span class="desktop-icon-label">Perfis</span>
      <span class="users-launcher-caption">Em breve</span>
    </a>

    <a
      href="#"
      class="users-launcher-icon desktop-icon is-disabled"
      aria-disabled="true"
      title="Criar Utilizador (em breve)"
    >
      <span class="desktop-icon-face desktop-icon-folder">
        <span class="desktop-icon-folder-main" aria-hidden="true">📁</span>
        <span class="desktop-icon-folder-badge" aria-hidden="true">➕</span>
      </span>
      <span class="desktop-icon-label">Criar</span>
      <span class="users-launcher-caption">Em breve</span>
    </a>
  </div>
</section>
