{
  "name": "sysadmin",
  "version": "1.0.0",
  "description": "Sysadmin module - users, sessions and system integrations",
  "main": "src/server.js",
  "scripts": {
    "styles:build": "sass src/public/styles/scss/app.scss src/public/styles/style.css --no-source-map",
    "styles:watch": "sass --watch src/public/styles/scss/app.scss:src/public/styles/style.css --no-source-map",
    "start": "npm run styles:build && node src/server.js",
    "dev": "npm run styles:build && nodemon src/server.js",
    "test": "jest --runInBand --testPathIgnorePatterns=old_modulo --passWithNoTests",
    "pm2:start": "pm2 start src/server.js --name pdms-sysadmin",
    "pm2:start:watch": "pm2 start src/server.js --name pdms-sysadmin --watch --ignore-watch=\"node_modules .git logs\"",
    "pm2:restart": "pm2 restart pdms-sysadmin",
    "pm2:restart:watch": "pm2 restart pdms-sysadmin --watch",
    "pm2:restart:no-watch": "pm2 restart pdms-sysadmin --watch=false",
    "pm2:stop": "pm2 stop pdms-sysadmin",
    "pm2:delete": "pm2 delete pdms-sysadmin",
    "pm2:logs": "pm2 logs pdms-sysadmin",
    "pm2:status": "pm2 status"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.6.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.0.3",
    "ejs": "^3.1.8",
    "express": "^4.18.2",
    "morgan": "^1.10.1",
    "mysql2": "^3.11.3"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "nodemon": "^3.0.1",
    "sass": "^1.99.0",
    "supertest": "^7.2.2"
  }
}
