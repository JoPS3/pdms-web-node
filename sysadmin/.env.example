NODE_ENV=development
PORT=6001
BASE_PATH_DEV=/pdms-new/sysadmin
BASE_PATH_PROD=/pdms/sysadmin

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=pedaco
DB_PASSWORD=
DB_NAME=pedaco-000
DB_DIALECT=mysql

# Internal APIs agora usam validacao de sessao no gateway
# Enviar Authorization: Bearer <access_token>

# Gateway (para validação de sessão)
GATEWAY_BASE_PATH_DEV=/pdms-new
GATEWAY_BASE_PATH_PROD=/pdms
GATEWAY_VALIDATE_DEV=http://localhost:6000/pdms-new/validate-session
GATEWAY_VALIDATE_PROD=http://localhost:6000/pdms/validate-session
GATEWAY_ONEDRIVE_STATUS_DEV=http://localhost:6000/pdms-new/internal/onedrive/status
GATEWAY_ONEDRIVE_STATUS_PROD=http://localhost:6000/pdms/internal/onedrive/status
GATEWAY_ONEDRIVE_SETUP_DEV=http://localhost:6000/pdms-new/internal/onedrive/setup
GATEWAY_ONEDRIVE_SETUP_PROD=http://localhost:6000/pdms/internal/onedrive/setup
GATEWAY_ONEDRIVE_CONNECT_DEV=http://localhost:6000/pdms-new/internal/onedrive/connect
GATEWAY_ONEDRIVE_CONNECT_PROD=http://localhost:6000/pdms/internal/onedrive/connect
GATEWAY_ONEDRIVE_DISCONNECT_DEV=http://localhost:6000/pdms-new/internal/onedrive/disconnect
GATEWAY_ONEDRIVE_DISCONNECT_PROD=http://localhost:6000/pdms/internal/onedrive/disconnect

# Auditoria remota no modulo mapas
MAPAS_AUDIT_LOG_URL_DEV=http://localhost:6002/pdms-new/mapas/internal/auditoria/log
MAPAS_AUDIT_LOG_URL_PROD=http://localhost:6002/pdms/mapas/internal/auditoria/log
