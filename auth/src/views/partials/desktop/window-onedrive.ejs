<section class="users-launcher-grid" aria-label="Acoes OneDrive">
  <button
    type="button"
    class="users-launcher-icon"
    data-onedrive-action="connect"
    title="Autenticar e ligar ao OneDrive"
    aria-label="Autenticar e ligar ao OneDrive"
  >
    <span class="users-launcher-glyph">🔐</span>
    <span class="users-launcher-name">Autenticar</span>
    <span class="users-launcher-caption">Ligar conta OneDrive</span>
  </button>

  <button
    type="button"
    class="users-launcher-icon"
    data-onedrive-action="status"
    title="Ver estado da ligacao OneDrive"
    aria-label="Ver estado da ligacao OneDrive"
  >
    <span class="users-launcher-glyph">📡</span>
    <span class="users-launcher-name">Estado</span>
    <span class="users-launcher-caption">Sessao e permissoes</span>
  </button>

  <button
    type="button"
    class="users-launcher-icon"
    data-onedrive-action="disconnect"
    title="Desligar conta OneDrive"
    aria-label="Desligar conta OneDrive"
  >
    <span class="users-launcher-glyph">🔌</span>
    <span class="users-launcher-name">Desligar</span>
    <span class="users-launcher-caption">Revogar ligacao ativa</span>
  </button>

  <button
    type="button"
    class="users-launcher-icon"
    data-open-window="onedrive-setup"
    title="Configurar OAuth OneDrive"
    aria-label="Configurar OAuth OneDrive"
  >
    <span class="users-launcher-glyph">⚙️</span>
    <span class="users-launcher-name">Configurar</span>
    <span class="users-launcher-caption">Setup OAuth</span>
  </button>
</section>

<div class="onedrive-status-panel" data-onedrive-status-panel hidden>
  <span class="onedrive-status-text" data-onedrive-status-text></span>
  <button type="button" class="onedrive-status-dismiss" data-onedrive-status-dismiss aria-label="Fechar mensagem">×</button>
</div>

<div class="onedrive-confirm-modal" data-onedrive-confirm-modal hidden>
  <p class="onedrive-confirm-message">Tem a certeza que pretende revogar a ligacao ao OneDrive?</p>
  <div class="onedrive-confirm-actions">
    <button type="button" class="password-submit onedrive-confirm-btn-danger" data-onedrive-confirm="yes">Desligar</button>
    <button type="button" class="password-submit" data-onedrive-confirm="no">Cancelar</button>
  </div>
</div>
