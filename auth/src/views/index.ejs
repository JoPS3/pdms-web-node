<!DOCTYPE html>
<html lang="pt">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %> | PDMS Auth</title>
    <link rel="stylesheet" href="<%= basePath %>/styles/style.css?v=<%= assetVersion %>" />
  </head>
  <body class="apps-page desktop-page">
    <div class="mobile-shell">
      <header class="mobile-header">
        <div class="mobile-header-content">
          <div>
            <h1>PDMS Auth</h1>
          </div>
          <div class="mobile-user">
            Sessao ativa de <strong><%= userName %></strong><br />
            <% if (userRole) { %>
              <span><%= userRole %></span>
            <% } %>
          </div>
          <a class="mobile-back" href="<%= gatewayBasePath %>/apps">Launcher</a>
        </div>
      </header>

      <main class="mobile-main">
        <h2>Centro de Autenticacao</h2>
        <div class="mobile-unavailable-card">
          <p>Esta aplicacao e dedicada a fluxos autenticados e endpoints internos.</p>
          <p><strong>ID de utilizador:</strong> <%= userId || 'n/d' %></p>
          <p>
            <a class="mobile-back" href="<%= basePath %>/utilizadores">Abrir utilizadores</a>
          </p>
        </div>
      </main>
    </div>

    <div class="desktop-shell" aria-label="Desktop de modulos">
      <header class="desktop-titlebar">
        <div class="titlebar-left">
          <span class="traffic-light red" aria-hidden="true"></span>
          <span class="traffic-light yellow" aria-hidden="true"></span>
          <span class="traffic-light green" aria-hidden="true"></span>
          <strong class="desktop-brand">PDMS - Modulo Auth</strong>
        </div>

        <div class="titlebar-center">
          <span class="desktop-clock" id="desktopClock">--:--</span>
        </div>

        <div class="titlebar-right">
          <span class="desktop-user">
            <strong><%= userName %></strong>
            <% if (userRole) { %><span class="desktop-user-role"><%= userRole %></span><% } %>
          </span>
          <a class="titlebar-back" href="<%= gatewayBasePath %>/apps" title="Voltar ao launcher">◀</a>
          <form method="post" action="<%= gatewayBasePath %>/logout" class="titlebar-logout">
            <button type="submit" title="Terminar sessao" aria-label="Terminar sessao">⏻</button>
          </form>
        </div>
      </header>

      <main class="desktop-workspace">
        <section class="desktop-icons" aria-label="Atalhos de auth">
          <button
            type="button"
            class="desktop-icon"
            data-open-window="session"
            title="Sessão"
            aria-label="Abrir sessão"
          >
            <span class="desktop-icon-glyph">📋</span>
            <span class="desktop-icon-name">Sessão</span>
          </button>
          <button
            type="button"
            class="desktop-icon"
            data-open-window="users"
            title="Utilizadores"
            aria-label="Abrir utilizadores"
          >
            <span class="desktop-icon-glyph">👥</span>
            <span class="desktop-icon-name">Utilizadores</span>
          </button>
        </section>
      </main>

      <nav class="desktop-dock" aria-label="Dock de modulos">
        <div class="dock-inner">
          <button
            type="button"
            class="dock-item"
            data-open-window="session"
            title="Sessão"
            aria-label="Abrir sessão"
          >
            <span class="dock-item-glyph">📋</span>
          </button>
          <button
            type="button"
            class="dock-item"
            data-open-window="users"
            title="Utilizadores"
            aria-label="Abrir utilizadores"
          >
            <span class="dock-item-glyph">👥</span>
          </button>
          <a class="dock-back" href="<%= gatewayBasePath %>/apps" aria-label="Voltar ao launcher">◀</a>
        </div>
      </nav>

      <!-- Windows container (single DOM, state-driven visibility) -->
      <div class="desktop-windows-container">
        <%- include('partials/desktop/window-backdrop') %>
        
        <!-- Session window with embedded content -->
        <div class="desktop-window window-session" id="window-session" hidden>
          <div class="desktop-window-titlebar">
            <strong class="desktop-window-title">Sessão</strong>
            <button
              type="button"
              class="desktop-window-close"
              data-close-window="session"
              aria-label="Fechar janela"
              title="Fechar"
            >
              ×
            </button>
          </div>
          <div class="desktop-window-content">
            <%- include('partials/desktop/window-session', { session: session }) %>
          </div>
        </div>

        <!-- Session info child window (smaller than session launcher) -->
        <div class="desktop-window window-session-info" id="window-session-info" hidden>
          <div class="desktop-window-titlebar">
            <strong class="desktop-window-title">Detalhes de Sessão</strong>
            <button
              type="button"
              class="desktop-window-close"
              data-close-window="session-info"
              aria-label="Fechar janela"
              title="Fechar"
            >
              ×
            </button>
          </div>
          <div class="desktop-window-content">
            <%- include('partials/desktop/window-session-info', { session: session }) %>
          </div>
        </div>
        
        <!-- Users window with embedded content -->
        <div class="desktop-window window-users" id="window-users" hidden>
          <div class="desktop-window-titlebar">
            <strong class="desktop-window-title">Utilizadores</strong>
            <button
              type="button"
              class="desktop-window-close"
              data-close-window="users"
              aria-label="Fechar janela"
              title="Fechar"
            >
              ×
            </button>
          </div>
          <div class="desktop-window-content">
            <%- include('partials/desktop/window-users', { session: session }) %>
          </div>
        </div>
      </div>
    </div>

    <script>
      (function attachDesktopClock() {
        var clock = document.getElementById('desktopClock');
        if (!clock) {
          return;
        }

        function renderTime() {
          var now = new Date();
          clock.textContent = now.toLocaleTimeString('pt-PT', {
            hour: '2-digit',
            minute: '2-digit'
          });
        }

        renderTime();
        setInterval(renderTime, 1000);
      })();
    </script>

    <!-- Global shell script: manages windows, overlay, drag, state -->
    <script src="<%= basePath %>/scripts/shell.js?v=<%= assetVersion %>"></script>
  </body>
</html>