{
  "name": "pdms-gateway",
  "version": "0.1.0",
  "description": "Gateway skeleton para autenticação e acesso a aplicações",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "start:pm2": "npm run styles:build && node src/server.js",
    "styles:build": "sass src/public/styles/scss/app.scss src/public/styles/app.css --no-source-map",
    "styles:watch": "sass --watch src/public/styles/scss/app.scss:src/public/styles/app.css",
    "test": "jest --runInBand --passWithNoTests",
    "test:watch": "jest --watch",
    "pm2:start": "pm2 start ecosystem.config.cjs --only pdms-gateway",
    "pm2:restart": "pm2 restart ecosystem.config.cjs --only pdms-gateway --update-env",
    "pm2:stop": "pm2 stop pdms-gateway",
    "pm2:delete": "pm2 delete pdms-gateway",
    "pm2:logs": "pm2 logs pdms-gateway"
  },
  "keywords": [
    "gateway",
    "express",
    "skeleton"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.7",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-mysql-session": "^3.0.3",
    "express-session": "^1.18.1",
    "helmet": "^8.1.0",
    "morgan": "^1.10.0",
    "mysql2": "^3.9.7"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.10",
    "sass": "^1.93.2"
  }
}
