<!DOCTYPE html>
<html lang="pt">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %> | Gateway</title>
    <link rel="stylesheet" href="<%= basePath %>/styles/app.css" />
  </head>
  <body class="main-page bg-warm">
    <div class="mobile-shell bg-mobile">
      <header class="mobile-header">
        <div class="mobile-header-content">
          <div>
            <h1>PDMS</h1>
          </div>
          <div class="mobile-user">
            Bem-vindo, <strong><%= userName %></strong><br />
            <% if (userRole) { %>
              <span><%= userRole %></span>
            <% } %>
          </div>
          <form method="post" action="<%= basePath %>/logout" class="mobile-logout">
            <button type="submit">Sair</button>
          </form>
        </div>
      </header>

      <main class="mobile-main">
        <h2>Aplicações Disponíveis</h2>

        <div class="mobile-apps-grid">
          <% apps.forEach((app) => { %>
            <article class="ui-card ui-card--mobile ui-card--compact">
              <h3><%= app.icon %> <%= app.name %></h3>
              <p><%= app.description %></p>
              <a href="<%= app.url %>" class="btn <%= app.url === '#' ? 'btn-secondary is-disabled' : 'btn-primary' %>"><%= app.url === '#' ? 'Em breve' : 'Abrir' %></a>
            </article>
          <% }) %>
        </div>
      </main>

      <footer class="mobile-footer">
        <p class="m-0">&copy; 2026 Pedaço Decimal Unipessoal Lda</p>
      </footer>
    </div>

    <div class="desktop-shell bg-desktop" aria-label="Desktop de aplicações">
      <%- include('./partials/desktop-title-bar', { userName, userRole, basePath }) %>

      <main class="desktop-workspace">
        <%- include('./partials/desktop-icons', { apps }) %>
      </main>

      <%- include('./partials/desktop-dock', { apps, basePath }) %>
    </div>

    <script src="<%= basePath %>/scripts/shell-clock.js" defer></script>
  </body>
</html>
