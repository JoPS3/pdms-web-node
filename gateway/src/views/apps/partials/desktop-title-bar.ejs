<header class="desktop-titlebar">
  <div class="titlebar-left">
    <span class="traffic-light red" aria-hidden="true"></span>
    <span class="traffic-light yellow" aria-hidden="true"></span>
    <span class="traffic-light green" aria-hidden="true"></span>
    <strong class="desktop-brand">PDMS - Pedaço Decimal Management System</strong>
  </div>

  <div class="titlebar-center">
    <span class="desktop-clock" id="desktopClock">--:--</span>
  </div>

  <div class="titlebar-right">
    <span class="desktop-user">
      <strong><%= userName %></strong>
      <% if (userRole) { %><span class="desktop-user-role"><%= userRole %></span><% } %>
    </span>
    <form method="post" action="<%= basePath %>/logout" class="titlebar-logout">
      <button type="submit" title="Terminar sessão">⏻</button>
    </form>
  </div>
</header>
