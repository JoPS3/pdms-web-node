<!DOCTYPE html>
<html lang="pt">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Página não encontrada | Gateway</title>
    <link rel="stylesheet" href="<%= basePath %>/styles/app.css" />
  </head>
  <body class="error-desktop-page">
    <header class="error-desktop-titlebar">
      <div class="error-desktop-lights">
        <span class="ui-traffic-light red"></span>
        <span class="ui-traffic-light yellow"></span>
        <span class="ui-traffic-light green"></span>
      </div>
      <strong class="error-desktop-brand">PDMS Gateway</strong>
      <span></span>
    </header>

    <main class="error-desktop-workspace">
      <section class="error-desktop-card">
        <p class="ui-error-code">404</p>
        <h1 class="ui-error-title">Página não encontrada</h1>
        <p class="ui-error-message">
          O recurso que procura não existe ou foi movido para outro local.
        </p>

        <div class="ui-error-actions">
          <% if (basePath) { %>
            <a href="<%= basePath %>/apps" class="btn btn-primary">Voltar às Apps</a>
          <% } else { %>
            <a href="/apps" class="btn btn-primary">Voltar às Apps</a>
          <% } %>
          <a href="<%= basePath %>/login" class="btn btn-secondary">Entrar</a>
        </div>

        <p class="ui-error-hint">
          Se acha que isto é um erro, contacte o administrador do sistema.
        </p>
      </section>
    </main>
  </body>
</html>
