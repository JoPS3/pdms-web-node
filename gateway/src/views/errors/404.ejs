<!DOCTYPE html>
<html lang="pt">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Página não encontrada | Gateway</title>
    <link rel="stylesheet" href="<%= basePath %>/styles/app.css" />
  </head>
  <body>
    <main class="card">
      <p class="error-code">404</p>
      <h1 class="error-title">Página não encontrada</h1>
      <p class="error-message">
        O recurso que está procurando não existe ou foi movido para outro local.
      </p>

      <div class="action-links">
        <% if (basePath) { %>
          <a href="<%= basePath %>">Voltar ao início</a>
        <% } else { %>
          <a href="/">Voltar ao início</a>
        <% } %>
        <a href="<%= basePath %>/login" class="secondary">Entrar</a>
      </div>

      <p class="hint error-hint">
        Se acha que isto é um erro, contacte o administrador do sistema.
      </p>
    </main>
  </body>
</html>
