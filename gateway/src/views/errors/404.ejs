<!DOCTYPE html>
<html lang="pt">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Página não encontrada | Gateway</title>
    <link rel="stylesheet" href="<%= basePath %>/styles/app.css" />
  </head>
  <body class="error-mobile-page">
    <main class="ui-card ui-card--mobile ui-card--elevated error-mobile-card">
      <p class="ui-error-code">404</p>
      <h1 class="ui-error-title">Página não encontrada</h1>
      <p class="ui-error-message">
        O recurso que está procurando não existe ou foi movido para outro local.
      </p>

      <div class="ui-error-actions">
        <% if (basePath) { %>
          <a href="<%= basePath %>" class="btn btn-primary">Voltar ao início</a>
        <% } else { %>
          <a href="/" class="btn btn-primary">Voltar ao início</a>
        <% } %>
        <a href="<%= basePath %>/login" class="btn btn-secondary">Entrar</a>
      </div>

      <p class="ui-error-hint">
        Se acha que isto é um erro, contacte o administrador do sistema.
      </p>
    </main>
  </body>
</html>
