<!DOCTYPE html>
<html lang="pt">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %> | Gateway</title>
    <link rel="stylesheet" href="<%= basePath %>/styles/main.css" />
  </head>
  <body>
    <main class="card">
      <h1>Entrar</h1>
      <p style="color: var(--muted); margin: 0 0 14px;">Bem-vindo, <strong><%= userName %></strong>.</p>
      
      <form method="post" action="<%= basePath %>/verify-password" id="login-form">
        <input type="hidden" name="userId" value="<%= userId %>" />

        <label for="password">Password</label>
        <input 
          id="password" 
          name="password" 
          type="password" 
          autocomplete="current-password"
          required 
          autofocus 
        />

        <button type="submit">Entrar</button>
      </form>

      <div id="status" class="status">
        <% if (errorMessage) { %>
        <span class="error"><%= errorMessage %></span>
        <% } %>
      </div>
      <p class="hint">Introduza a sua password para aceder.</p>
    </main>
  </body>
</html>
