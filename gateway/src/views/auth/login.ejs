<!DOCTYPE html>
<html lang="pt">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %> | Gateway</title>
    <link rel="stylesheet" href="<%= basePath %>/styles/app.css" />
  </head>
  <body class="d-grid place-center bg-warm p-24" data-base-path="<%= basePath %>">
    <main class="ui-card ui-card--mobile">
      <h1 class="ui-card__title">Entrar</h1>
      <form id="login-form">
        <label for="username" class="auth-label">Utilizador</label>
        <input id="username" name="username" class="auth-input" autocomplete="username" required autofocus />

        <button type="submit" class="btn btn-primary btn-lg btn-block auth-submit">Continuar</button>
      </form>

      <div id="status" class="status auth-status">
        <% if (errorMessage) { %>
        <span class="error"><%= errorMessage %></span>
        <% } %>
      </div>
      <p class="ui-card__hint">Apenas utilizadores autorizados podem entrar. Introduza o seu utilizador para continuar.</p>
    </main>

    <script src="<%= basePath %>/scripts/auth-forms.js" defer></script>
  </body>
</html>
