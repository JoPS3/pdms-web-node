<!DOCTYPE html>
<html lang="pt">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %> | Gateway</title>
    <link rel="stylesheet" href="<%= basePath %>/styles/main.css" />
  </head>
  <body>
    <main class="card">
      <h1>Definir Password</h1>
      <p style="color: var(--muted); margin: 0 0 14px;">Bem-vindo, <strong><%= userName %></strong>. Defina uma password para continuar.</p>
      
      <form method="post" action="<%= basePath %>/set-password" id="set-password-form">
        <input type="hidden" name="userId" value="<%= userId %>" />

        <label for="password">Password</label>
        <input 
          id="password" 
          name="password" 
          type="password" 
          placeholder="Mínimo 8 caracteres"
          required 
          autofocus 
        />

        <label for="password-confirm">Confirmar Password</label>
        <input 
          id="password-confirm" 
          name="passwordConfirm" 
          type="password" 
          placeholder="Confirme a password"
          required 
        />

        <button type="submit">Definir Password</button>
      </form>

      <div id="status" class="status">
        <% if (errorMessage) { %>
        <span class="error"><%= errorMessage %></span>
        <% } %>
      </div>
      <p class="hint">A password deve ter no mínimo 8 caracteres e conter números e letras para maior segurança.</p>
    </main>

    <script>
      document.getElementById('set-password-form').addEventListener('submit', function(e) {
        const pwd = document.getElementById('password').value;
        const confirm = document.getElementById('password-confirm').value;

        if (pwd !== confirm) {
          e.preventDefault();
          document.getElementById('status').innerHTML = '<span class="error">As passwords não coincidem</span>';
          return false;
        }

        if (pwd.length < 8) {
          e.preventDefault();
          document.getElementById('status').innerHTML = '<span class="error">Password deve ter no mínimo 8 caracteres</span>';
          return false;
        }
      });
    </script>
  </body>
</html>
