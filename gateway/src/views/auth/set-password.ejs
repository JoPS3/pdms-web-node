<!DOCTYPE html>
<html lang="pt">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %> | Gateway</title>
    <link rel="stylesheet" href="<%= basePath %>/styles/app.css" />
  </head>
  <body class="d-grid place-center bg-warm p-24" data-base-path="<%= basePath %>">
    <main class="ui-card ui-card--mobile">
      <h1 class="ui-card__title">Definir Password</h1>
      <p class="ui-card__lead">Bem-vindo, <strong><%= userName %></strong>. Defina uma password para continuar.</p>

      <form id="set-password-form" data-user-id="<%= userId %>">

        <label for="password" class="auth-label">Password</label>
        <input
          id="password"
          name="password"
          class="auth-input"
          type="password"
          placeholder="Mínimo 8 caracteres"
          required
          autofocus
        />

        <label for="password-confirm" class="auth-label">Confirmar Password</label>
        <input
          id="password-confirm"
          name="passwordConfirm"
          class="auth-input"
          type="password"
          placeholder="Confirme a password"
          required
        />

        <button type="submit" class="btn btn-primary btn-lg btn-block auth-submit">Definir Password</button>
      </form>

      <div id="status" class="status auth-status"></div>
      <p class="ui-card__hint">A password deve ter no mínimo 8 caracteres e conter números e letras para maior segurança.</p>
    </main>

    <script src="<%= basePath %>/scripts/auth-forms.js" defer></script>
  </body>
</html>
