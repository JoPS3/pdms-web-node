{
  "name": "mapas",
  "version": "1.0.0",
  "description": "Mapas module - clean Node+Express architecture",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --runInBand --testPathIgnorePatterns=old_modulo --passWithNoTests",
    "pm2:start": "pm2 start src/server.js --name pdms-mapas",
    "pm2:start:watch": "pm2 start src/server.js --name pdms-mapas --watch --ignore-watch=\"node_modules .git logs\"",
    "pm2:restart": "pm2 restart pdms-mapas",
    "pm2:restart:watch": "pm2 restart pdms-mapas --watch",
    "pm2:restart:no-watch": "pm2 restart pdms-mapas --watch=false",
    "pm2:stop": "pm2 stop pdms-mapas",
    "pm2:delete": "pm2 delete pdms-mapas",
    "pm2:logs": "pm2 logs pdms-mapas",
    "pm2:status": "pm2 status"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.6.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.0.3",
    "ejs": "^3.1.8",
    "express": "^4.18.2",
    "morgan": "^1.10.1",
    "mysql2": "^3.11.3"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "nodemon": "^3.0.1",
    "supertest": "^7.2.2"
  }
}
