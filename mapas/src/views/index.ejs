<!DOCTYPE html>
<html lang="pt">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %> | Mapas</title>
    <link rel="stylesheet" href="<%= basePath %>/styles/style.css?v=<%= assetVersion %>" />
  </head>
  <body class="main-page">
    <div class="mobile-shell">
      <header class="mobile-header">
        <div class="mobile-header-content">
          <div>
            <h1>PDMS Mapas</h1>
          </div>
          <div class="mobile-user">
            Bem-vindo, <strong><%= userName %></strong><br />
            <% if (userRole) { %>
              <span><%= userRole %></span>
            <% } %>
          </div>
          <a class="mobile-back" href="<%= gatewayBasePath %>/apps">Launcher</a>
        </div>
      </header>

      <main class="mobile-main">
        <h2>Modulos Disponiveis</h2>

        <div class="mobile-apps-grid">
          <% modules.forEach((module) => { %>
            <div class="mobile-app-card">
              <h3><%= module.icon %> <%= module.name %></h3>
              <p><%= module.description %></p>
              <a href="<%= module.url %>"><%= module.url === '#' ? 'Em breve' : 'Abrir' %></a>
            </div>
          <% }) %>
        </div>
      </main>

      <footer class="mobile-footer">
        <p style="margin: 0;">&copy; 2026 PDMS - Mapas</p>
      </footer>
    </div>

    <div class="desktop-shell" aria-label="Desktop de modulos">
      <header class="desktop-titlebar">
        <div class="titlebar-left">
          <form method="post" action="<%= gatewayBasePath %>/logout" class="traffic-light-logout" aria-label="Terminar sessao">
            <button type="submit" class="traffic-light-button red" title="Terminar sessao" aria-label="Terminar sessao"></button>
          </form>
          <span class="traffic-light yellow" aria-hidden="true"></span>
          <span class="traffic-light green" aria-hidden="true"></span>
          <strong class="desktop-brand">PDMS - Modulo Mapas</strong>
        </div>

        <div class="titlebar-center">
          <span class="desktop-clock" id="desktopClock">--:--</span>
        </div>

        <div class="titlebar-right">
          <span class="desktop-user">
            <strong><%= userName %></strong>
            <% if (userRole) { %><span class="desktop-user-role"><%= userRole %></span><% } %>
          </span>
          <a class="titlebar-back" href="<%= gatewayBasePath %>/apps" title="Voltar ao launcher">◀</a>
        </div>
      </header>

      <main class="desktop-workspace">
        <section class="desktop-icons" aria-label="Atalhos de modulos">
          <% modules.forEach((module) => { %>
            <a
              class="desktop-icon <%= module.url === '#' ? 'is-disabled' : '' %>"
              href="<%= module.url %>"
              <% if (module.url && module.url.includes('/diario-caixa')) { %>data-open-diario-window="1"<% } %>
              <% if (module.url && module.url.includes('/auditoria-logs')) { %>data-open-auditoria-window="1"<% } %>
              title="<%= module.name %>"
              aria-label="Abrir <%= module.name %>"
            >
              <span class="desktop-icon-glyph"><%= module.icon %></span>
              <span class="desktop-icon-name"><%= module.name %></span>
            </a>
          <% }) %>
        </section>
      </main>

      <%- include('windows/diario-caixa') %>
      <%- include('windows/auditoria-logs') %>

      <nav class="desktop-dock" aria-label="Dock de modulos">
        <div class="dock-inner">
          <% modules.forEach((module) => { %>
            <a
              class="dock-item <%= module.url === '#' ? 'is-disabled' : '' %>"
              href="<%= module.url %>"
              <% if (module.url && module.url.includes('/diario-caixa')) { %>data-open-diario-window="1"<% } %>
              <% if (module.url && module.url.includes('/auditoria-logs')) { %>data-open-auditoria-window="1"<% } %>
              title="<%= module.name %>"
              aria-label="Abrir <%= module.name %>"
            >
              <span class="dock-item-glyph"><%= module.icon %></span>
            </a>
          <% }) %>
          <a class="dock-back" href="<%= gatewayBasePath %>/apps" aria-label="Voltar ao launcher">◀</a>
        </div>
      </nav>
    </div>

    <script src="<%= basePath %>/scripts/desktop-shell.js?v=<%= assetVersion %>"></script>
  </body>
</html>
